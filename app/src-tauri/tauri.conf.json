{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kosmos",
  "version": "0.1.0",
  "identifier": "com.kosmos.viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kosmos",
        "width": 960,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/kosmos-capture"]
  }
}
